{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "incremental": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "strict": false,
    "noImplicitAny": false,
    // TODO: These includes need to be removed in the future due to typing in modules, functions and properties.
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "strictPropertyInitialization": false,
    "forceConsistentCasingInFileNames": true,
    //
    "noEmit": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
  },
  "include": [
    "config/**/*",
    "lib/**/*",
    "server/**/*",
    "./dist/.next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "docs",
    "server/**/*.spec.ts"
  ]
}
