{
    "compilerOptions": {
        "module": "commonjs",
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "target": "es2017",
        "sourceMap": true,
        "outDir": "../dist/",
        "rootDir": "../",
        "incremental": true,
        "strictNullChecks": true,
        "noImplicitAny": true,
        "useUnknownInCatchVariables": false,
        "strictPropertyInitialization": false,
        //
    },
    "include": ["./**/*"],
    "exclude": [
        "node_modules",
        "./**/*.spec.ts",
    ]
}
